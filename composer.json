{
    "name": "yourcompany/security-erp",
    "type": "project",
    "description": "Security ERP System",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^13.0",
        "barryvdh/laravel-dompdf": "^3.0",
        "laravel/tinker": "^3.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "phpunit/phpunit": "^12.0",
        "laravel/pail": "^1.2",
        "laravel/pao": "^1.1",
        "nunomaduro/collision": "^8.9",
        "laravel/breeze": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
